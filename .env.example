# anchor-admin env vars
# Vite dev server proxies /api → http://localhost:3002 (anchor-backend
# admin server). To point at a different backend instance, edit vite.config.ts.

# OAuth login portal (used by client/src/const.ts → getLoginUrl)
# VITE_OAUTH_PORTAL_URL=https://oauth.example.com
# VITE_APP_ID=anchor-admin
